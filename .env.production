# NEXUS PROTOCOL - Production Environment
# Copy to .env and fill in real values before deploying

# PostgreSQL
POSTGRES_DB=nexusprotocol
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=CHANGE_ME

# Backend
JWT_SECRET=CHANGE_ME_MIN_64_CHARS
CORS_ORIGIN=http://YOUR_SERVER_IP_OR_DOMAIN

# Frontend port (nginx)
FRONTEND_PORT=80
