# NEXUS PROTOCOL Environment Configuration

NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=3000

# Database (in-memory, but required for startup check)
POSTGRES_PASSWORD=nexus_dev_password_2026

# Security
JWT_SECRET=nexus_protocol_super_secret_key_for_dev_environment_2026_minimum_32_chars
JWT_EXPIRATION=24h

# CORS - Allow the Vite dev server
CORS_ORIGIN=http://localhost:5173,http://localhost:5175,http://localhost:5176,http://localhost:5177

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# WebSocket
WS_MESSAGE_RATE_LIMIT=10
WS_MESSAGE_SIZE_LIMIT=100000
